# =========================================================================
# Luxe Perfume — Environment Variables
# Copy this file to .env and adjust values for your environment.
# =========================================================================

# ----- Core -----
PROJECT_NAME=luxe-perfume
ENVIRONMENT=production
DEBUG=False
SECRET_KEY=replace-with-a-50-char-random-secret
ALLOWED_HOSTS=luxeperfume.in,www.luxeperfume.in,api.luxeperfume.in
FRONTEND_URL=https://luxeperfume.in
ADMIN_URL=admin

# ----- Database -----
POSTGRES_DB=luxe
POSTGRES_USER=luxe
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ----- Redis -----
REDIS_URL=redis://redis:6379/0
CACHE_URL=redis://redis:6379/1

# ----- JWT -----
JWT_ACCESS_LIFETIME_MIN=60
JWT_REFRESH_LIFETIME_DAYS=14

# ----- Email (SMTP) -----
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.zoho.in
EMAIL_PORT=587
EMAIL_HOST_USER=hello@luxeperfume.in
EMAIL_HOST_PASSWORD=app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL="Luxe Perfume <hello@luxeperfume.in>"

# ----- Storage (Cloudflare R2 / S3) -----
USE_S3=True
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=luxe-media
AWS_S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
AWS_S3_REGION_NAME=auto
AWS_S3_CUSTOM_DOMAIN=cdn.luxeperfume.in
MEDIA_URL=https://cdn.luxeperfume.in/

# ----- Razorpay -----
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx

# ----- Rate limiting / Security -----
CORS_ALLOWED_ORIGINS=https://luxeperfume.in,https://www.luxeperfume.in
CSRF_TRUSTED_ORIGINS=https://luxeperfume.in,https://www.luxeperfume.in
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
